# Real Canary 0: only K8s/Sealos is real.
APP_NAME=ai-api-saas-control-plane
APP_ENV=dev
API_KEY=change-me-admin-token

DATABASE_URL=postgresql+psycopg://saas:saas@db:5432/saas
REDIS_URL=redis://redis:6379/0

ALLOW_REAL_EXTERNAL_CALLS=true
REAL_EXTERNAL_ALLOWLIST=k8s

APPLY_K8S=true
K8S_APPLY_MODE=real
K8S_SERVER_DRY_RUN_FIRST=true
KUBECONFIG_PATH=/app/.kube/sealos-canary.yaml
K8S_CONTEXT=
K8S_ROLLOUT_TIMEOUT_SECONDS=180
KUBECTL_TIMEOUT_SECONDS=180
# Required only when intentionally running scripts/real_k8s_canary_preflight.sh.
# That script touches the Kubernetes API with kubectl auth can-i checks.
# Set to I_UNDERSTAND_THIS_WILL_QUERY_K8S_API only after explicit human authorization.
REAL_K8S_PREFLIGHT_CONFIRM=

# Use fixed namespace first unless Sealos confirms namespace creation is allowed.
K8S_NAMESPACE_MODE=fixed
K8S_TARGET_NAMESPACE=your-sealos-test-namespace
K8S_CREATE_NAMESPACE=false
K8S_NAMESPACE_PREFIX=ai-tenant

BASE_DOMAIN=your-test-domain.com
PUBLIC_GATEWAY_CNAME=ingress.your-test-domain.com
K8S_INGRESS_CLASS=your-sealos-ingress-class
K8S_TLS_SECRET_NAME=
K8S_POD_RUN_AS_USER=
K8S_POD_RUN_AS_GROUP=
K8S_POD_FS_GROUP=
K8S_CANARY_MODE=true
K8S_CANARY_MAX_LIFETIME_SECONDS=600

NEWAPI_IMAGE=calciumion/new-api:latest
NEWAPI_CONTAINER_PORT=3000
NEWAPI_DEFAULT_REPLICAS=1

# Real DB/Redis are needed for the New API pod to actually become Ready.
NEWAPI_SQL_DSN_TEMPLATE=postgresql://user:pass@host:5432/dbname
NEWAPI_REDIS_CONN_TEMPLATE=redis://:pass@host:6379/0
NEWAPI_SESSION_SECRET_PREFIX=change-me-session
NEWAPI_CRYPTO_SECRET_PREFIX=change-me-crypto
NEWAPI_TIMEZONE=Asia/Shanghai
NEWAPI_STREAMING_TIMEOUT_SECONDS=300
NEWAPI_ERROR_LOG_ENABLED=true
NEWAPI_BATCH_UPDATE_ENABLED=true

# Keep all non-K8s adapters mocked.
NEWAPI_MOCK=true
SUB2API_MOCK=true
CLOUDFLARE_MOCK=true

# Optional placeholders; should not be used while mocks are true.
NEWAPI_ADMIN_TOKEN=
NEWAPI_ADMIN_USER_ID=
NEWAPI_CHANNEL_PATH=/api/channel/
NEWAPI_TOKEN_PATH=/api/token/
NEWAPI_CHANNEL_MODE=single
NEWAPI_CHANNEL_TYPE=1
NEWAPI_CHANNEL_MODELS=gpt-4o,gpt-4o-mini,claude-3-5-sonnet,gemini-1.5-pro
NEWAPI_CHANNEL_GROUP=default

SUB2API_BASE_URL=
SUB2API_ADMIN_KEY=
SUB2API_TENANT_KEY=
SUB2API_KEY_PREFIX=sub2api-placeholder-key

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_CUSTOM_HOSTNAME_FALLBACK_ORIGIN=

MANIFEST_OUTPUT_DIR=/app/generated-manifests
MOCK_RUNTIME_DIR=/app/mock-runtime
PROVISION_WAIT_SECONDS=0.05
WORKFLOW_RETRY_BACKOFF_SECONDS=0.05
