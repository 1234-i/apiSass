# Copy to .env.real only when you are ready to test one real station.
APP_NAME=ai-api-saas-control-plane
APP_ENV=real-test
API_KEY=replace-with-a-strong-admin-token
ALLOW_REAL_EXTERNAL_CALLS=true

DATABASE_URL=postgresql+psycopg://saas:saas@db:5432/saas
REDIS_URL=redis://redis:6379/0

BASE_DOMAIN=yourdomain.com
PUBLIC_GATEWAY_CNAME=ingress.yourdomain.com
K8S_NAMESPACE_PREFIX=ai-tenant
K8S_INGRESS_CLASS=nginx
K8S_TLS_SECRET_NAME=your-wildcard-tls-secret
K8S_POD_RUN_AS_USER=
K8S_POD_RUN_AS_GROUP=
K8S_POD_FS_GROUP=
K8S_CANARY_MODE=false
K8S_CANARY_MAX_LIFETIME_SECONDS=600
KUBECTL_TIMEOUT_SECONDS=180

NEWAPI_IMAGE=calciumion/new-api:latest
NEWAPI_CONTAINER_PORT=3000
NEWAPI_DEFAULT_REPLICAS=1
NEWAPI_SQL_DSN_TEMPLATE=postgresql://user:password@host:5432/newapi_{slug}
NEWAPI_REDIS_CONN_TEMPLATE=redis://:password@host:6379/0
NEWAPI_SESSION_SECRET_PREFIX=replace-session-secret-prefix
NEWAPI_CRYPTO_SECRET_PREFIX=replace-crypto-secret-prefix
NEWAPI_TIMEZONE=Asia/Shanghai
NEWAPI_STREAMING_TIMEOUT_SECONDS=300
NEWAPI_ERROR_LOG_ENABLED=true
NEWAPI_BATCH_UPDATE_ENABLED=true
NEWAPI_MOCK=false
NEWAPI_ADMIN_TOKEN=replace-with-new-api-access-token
NEWAPI_ADMIN_USER_ID=
NEWAPI_CHANNEL_PATH=/api/channel/
NEWAPI_TOKEN_PATH=/api/token/
NEWAPI_CHANNEL_MODE=single
NEWAPI_CHANNEL_TYPE=1
NEWAPI_CHANNEL_MODELS=gpt-4o,gpt-4o-mini,claude-3-5-sonnet,gemini-1.5-pro
NEWAPI_CHANNEL_GROUP=default
NEWAPI_CHANNEL_PAYLOAD_TEMPLATE=

SUB2API_BASE_URL=https://sub2api.yourdomain.com
SUB2API_TENANT_KEY=replace-with-key-created-in-sub2api
SUB2API_ADMIN_KEY=change-me-sub2api-admin-key
SUB2API_MOCK=false

APPLY_K8S=true
K8S_APPLY_MODE=real
KUBECONFIG_PATH=/app/.kube/config
MANIFEST_OUTPUT_DIR=/app/generated-manifests
MOCK_RUNTIME_DIR=/app/mock-runtime

CLOUDFLARE_MOCK=true
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_CUSTOM_HOSTNAME_FALLBACK_ORIGIN=
