APP_NAME=ai-api-saas-control-plane
APP_ENV=dev
API_KEY=change-me-admin-token

# Global safety gate. Keep false for local/Codex validation.
ALLOW_REAL_EXTERNAL_CALLS=false
REAL_EXTERNAL_ALLOWLIST=

DATABASE_URL=postgresql+psycopg://saas:saas@db:5432/saas
REDIS_URL=redis://redis:6379/0

# Platform domain. For real flow, BASE_DOMAIN should be your wildcard domain.
BASE_DOMAIN=example.com
PUBLIC_GATEWAY_CNAME=ingress.example.com

K8S_NAMESPACE_PREFIX=ai-tenant
K8S_NAMESPACE_MODE=generated
K8S_TARGET_NAMESPACE=
K8S_CREATE_NAMESPACE=true
K8S_INGRESS_CLASS=nginx
K8S_TLS_SECRET_NAME=wildcard-example-com-tls
K8S_POD_RUN_AS_USER=
K8S_POD_RUN_AS_GROUP=
K8S_POD_FS_GROUP=
KUBECTL_TIMEOUT_SECONDS=180

NEWAPI_IMAGE=calciumion/new-api:latest
NEWAPI_CONTAINER_PORT=3000
NEWAPI_DEFAULT_REPLICAS=1
NEWAPI_SQL_DSN_TEMPLATE=REPLACE_WITH_SEALOS_DB_DSN_FOR_{slug}
NEWAPI_REDIS_CONN_TEMPLATE=REPLACE_WITH_SEALOS_REDIS_URL_FOR_{slug}
NEWAPI_SESSION_SECRET_PREFIX=change-me-session
NEWAPI_CRYPTO_SECRET_PREFIX=change-me-crypto
NEWAPI_TIMEZONE=Asia/Shanghai
NEWAPI_STREAMING_TIMEOUT_SECONDS=300
NEWAPI_ERROR_LOG_ENABLED=true
NEWAPI_BATCH_UPDATE_ENABLED=true

# New API management adapter. Real mode requires an Access Token generated in New API.
NEWAPI_ADMIN_TOKEN=
NEWAPI_ADMIN_USER_ID=
NEWAPI_MOCK=true
NEWAPI_HEALTH_PATH=/
NEWAPI_CHANNEL_PATH=/api/channel/
NEWAPI_TOKEN_PATH=/api/token/
NEWAPI_API_TIMEOUT_SECONDS=20
NEWAPI_CHANNEL_MODE=single
NEWAPI_CHANNEL_TYPE=1
NEWAPI_CHANNEL_MODELS=gpt-4o,gpt-4o-mini,claude-3-5-sonnet,gemini-1.5-pro
NEWAPI_CHANNEL_GROUP=default
# Optional JSON template. Variables: {name},{base_url},{api_key},{models},{group},{channel_type}
NEWAPI_CHANNEL_PAYLOAD_TEMPLATE=

# Sub2API: use Sub2API's own billing for downstream station settlement.
SUB2API_BASE_URL=https://sub2api.example.com
SUB2API_ADMIN_KEY=change-me-sub2api-admin-key
SUB2API_KEY_PREFIX=sub2api-placeholder-key
SUB2API_TENANT_KEY=
SUB2API_HEALTH_PATH=/health
SUB2API_MOCK=true

# K8s/Sealos apply. Default stays mock.
APPLY_K8S=false
K8S_APPLY_MODE=mock
KUBECONFIG_PATH=/app/.kube/config
K8S_CONTEXT=
K8S_ROLLOUT_TIMEOUT_SECONDS=180
K8S_SERVER_DRY_RUN_FIRST=true
MANIFEST_OUTPUT_DIR=/app/generated-manifests
MOCK_RUNTIME_DIR=/app/mock-runtime
PROVISION_WAIT_SECONDS=0.05
WORKFLOW_RETRY_BACKOFF_SECONDS=0.05

# Cloudflare is optional for custom domains. Wildcard platform subdomains can stay Cloudflare mock.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_CUSTOM_HOSTNAME_FALLBACK_ORIGIN=
CLOUDFLARE_MOCK=true

DEFAULT_RPM=60
DEFAULT_TPM=100000
DEFAULT_MONTHLY_LIMIT=10000000
